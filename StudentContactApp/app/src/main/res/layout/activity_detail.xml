<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F9">

    <!-- Header / App Bar Buatan -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#3F51B5"
        android:padding="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Detail"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal"
        android:background="@android:color/white"
        android:elevation="4dp"
        android:layout_margin="16dp">

        <!-- Avatar Dummy -->
        <TextView
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/ic_launcher_background"
            android:text="AF"
            android:textColor="@android:color/white"
            android:gravity="center"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvDetailName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ahmad Fauzi"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#000000"/>

        <TextView
            android:id="@+id/tvDetailInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2024001 · T. Informatika"
            android:textSize="14sp"
            android:textColor="#757575"
            android:layout_marginBottom="24dp"/>

        <!-- Area Catatan -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FAFAFA"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📝 Catatan"
                android:textStyle="bold"
                android:textColor="#3F51B5"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/etNoteContent"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:hint="Tulis catatan di sini..."
                android:background="@android:drawable/edit_text"
                android:padding="8dp"
                android:gravity="top|start"
                android:inputType="textMultiLine"
                android:layout_marginBottom="16dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnSaveNote"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Simpan"
                    android:backgroundTint="#3F51B5"
                    android:textColor="@android:color/white"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/btnLoadNote"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Muat"
                    android:backgroundTint="#757575"
                    android:textColor="@android:color/white"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvNoteStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Belum ada catatan"
                android:textColor="#4CAF50"
                android:textSize="12sp"
                android:layout_marginTop="8dp"/>

        </LinearLayout>
    </LinearLayout>
</LinearLayout>